@page "/sessions"
@model Peers.Web.Pages.Sessions.IndexModel
@{
    ViewData["Title"] = "Sessions";
}

<section class="hero">
    <p class="eyebrow">Peers Training</p>
    <h1>Sessions</h1>
    <p class="lead">Pick a session to manage attendance, or create a new one.</p>
</section>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="notice notice-@Model.FlashTone" role="status" aria-live="polite">
        @Model.FlashMessage
    </div>
}

<section class="panel">
    <div class="panel-heading">
        <h2>All Sessions</h2>
        <a asp-page="/Sessions/New" class="btn btn-primary">Create session</a>
    </div>

    @if (Model.Sessions.Count == 0)
    {
        <div class="empty-state">
            <p>No sessions yet.</p>
            <p class="subtle">Create your first session to start tracking attendance.</p>
        </div>
    }
    else
    {
        <ul class="session-list session-list-spacious">
            @foreach (var session in Model.Sessions)
            {
                <li>
                    <a asp-page="/Sessions/Manage" asp-route-id="@session.SessionId" class="session-link">
                        <span class="session-name">@session.Name</span>
                        <span class="session-meta-row">
                            <span class="status-chip @(session.IsEnded ? "status-ended" : "status-active")">@(session.IsEnded ? "ended" : "active")</span>
                            <span class="meta">@session.ParticipantCount dancers</span>
                        </span>
                    </a>
                </li>
            }
        </ul>
    }
</section>
