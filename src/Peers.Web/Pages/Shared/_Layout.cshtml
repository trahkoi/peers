<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Peers</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Peers.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <div class="page-shell topbar-inner">
            <a class="brand" asp-area="" asp-page="/Sessions/Index">Peers</a>
            <nav aria-label="Main navigation">
                <a asp-area="" asp-page="/Sessions/Index" class="top-link">Sessions</a>
            </nav>
        </div>
    </header>

    <main class="page-shell">
        @RenderBody()
    </main>

    <footer class="page-shell footer">
        <p>&copy; 2026 Peers</p>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
